# GCP Configuration (for deployment)
GCP_PROJECT_ID=your-project-id
GCP_REGION=asia-northeast1

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Discord Configuration  
DISCORD_APPLICATION_ID=your-application-id
DISCORD_PUBLIC_KEY=your-public-key
DISCORD_BOT_TOKEN=your-bot-token

# ElevenLabs Configuration
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Google Drive Configuration (Optional - Choose one method)
# Method 1: Service Account (Recommended for production)
# Create a service account in Google Cloud Console and download the JSON key
# Then paste the entire JSON content as a single line
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Method 2: Impersonate a user (Optional)
# If you need to access files that are only shared with specific users
GOOGLE_IMPERSONATE_EMAIL=user@example.com

# Supabase Configuration (No longer needed for Cloud Run)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key